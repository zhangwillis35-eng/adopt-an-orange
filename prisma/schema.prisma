generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  ORCHARD_MANAGER
}

enum TreeStatus {
  AVAILABLE
  ADOPTED
  RESTING
  RETIRED
}

enum AdoptionStatus {
  ACTIVE
  HARVESTING
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  ACTIVE
  SHIPPING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  WECHAT
  ALIPAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ShipmentStatus {
  PREPARING
  SHIPPED
  IN_TRANSIT
  DELIVERED
}

enum UpdateType {
  GROWTH
  WEATHER
  CARE
  HARVEST
  EVENT
  LIVE
}

// ─── NextAuth Tables ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User & Address ──────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  phone        String?  @unique
  email        String?  @unique
  name         String?
  nickname     String?
  avatar       String?
  passwordHash String?
  role         Role     @default(CUSTOMER)
  wechatOpenId String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  adoptions Adoption[]
  accounts  Account[]
  sessions  Session[]
  reviews   Review[]
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  contactName String
  phone       String
  province    String
  city        String
  district    String
  detail      String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ─── Orchard & Tree ──────────────────────────────────────

model Orchard {
  id            String   @id @default(cuid())
  name          String
  location      String
  latitude      Float
  longitude     Float
  description   String   @db.Text
  coverImage    String?
  livestreamUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trees   OrangeTree[]
  updates OrchardUpdate[]
}

model OrangeTree {
  id             String     @id @default(cuid())
  orchardId      String
  treeCode       String     @unique
  variety        String
  age            Int
  status         TreeStatus @default(AVAILABLE)
  location       String?
  coverImage     String?
  estimatedYield Float?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  orchard   Orchard    @relation(fields: [orchardId], references: [id], onDelete: Cascade)
  adoptions Adoption[]
}

// ─── Adoption Plan ───────────────────────────────────────

model AdoptionPlan {
  id              String   @id @default(cuid())
  name            String
  description     String   @db.Text
  coverImage      String?
  price           Decimal  @db.Decimal(10, 2)
  duration        Int
  deliveryCount   Int
  estimatedWeight Float
  features        Json?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  adoptions Adoption[]
}

// ─── Adoption ────────────────────────────────────────────

model Adoption {
  id            String         @id @default(cuid())
  userId        String
  orderId       String         @unique
  planId        String
  treeId        String
  adoptionName  String?
  startDate     DateTime
  endDate       DateTime
  status        AdoptionStatus @default(ACTIVE)
  certificateNo String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order        @relation(fields: [orderId], references: [id])
  plan      AdoptionPlan @relation(fields: [planId], references: [id])
  tree      OrangeTree   @relation(fields: [treeId], references: [id])
  shipments Shipment[]
}

// ─── Order & Payment ─────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique
  userId      String
  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  addressId   String?
  remark      String?
  paidAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  address  Address?  @relation(fields: [addressId], references: [id])
  adoption Adoption?
  payments Payment[]
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  tradeNo   String?
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  rawData   Json?
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── Shipment ────────────────────────────────────────────

model Shipment {
  id              String         @id @default(cuid())
  adoptionId      String
  batch           Int
  weight          Float
  carrier         String?
  trackingNo      String?
  status          ShipmentStatus @default(PREPARING)
  shippedAt       DateTime?
  deliveredAt     DateTime?
  addressSnapshot Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  adoption Adoption @relation(fields: [adoptionId], references: [id], onDelete: Cascade)
}

// ─── Review ──────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  location  String
  rating    Int      @db.SmallInt
  content   String   @db.Text
  planName  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
}

// ─── Orchard Update ──────────────────────────────────────

model OrchardUpdate {
  id          String     @id @default(cuid())
  orchardId   String
  title       String
  content     String     @db.Text
  type        UpdateType
  mediaUrls   Json?
  publishedAt DateTime?
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  orchard Orchard @relation(fields: [orchardId], references: [id], onDelete: Cascade)
}
